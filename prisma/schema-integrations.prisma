// Расширение схемы для реальных интеграций

// Платформы закупок с детальными настройками
model PlatformIntegration {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Идентификация платформы
  platformType      PlatformType
  platformName      String   // zakupki.gov.ru, sberbank-ast.ru, etc.
  baseUrl           String
  
  // Авторизация
  authType          AuthType @default(CREDENTIALS)
  loginUrl          String?
  
  // Учетные данные (зашифрованы)
  encryptedCredentials Json  // { username, password, certificates, etc. }
  
  // Сессия
  sessionData       Json?    // cookies, tokens, etc.
  sessionExpiresAt  DateTime?
  lastLoginAt       DateTime?
  loginAttempts     Int      @default(0)
  
  // Статус
  status            IntegrationStatus @default(DISCONNECTED)
  lastError         String?
  lastCheckedAt     DateTime?
  
  // Настройки автоматизации
  autoLogin         Boolean  @default(false)
  checkInterval     Int      @default(3600) // seconds
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("platform_integrations")
}

// Telegram интеграции
model TelegramIntegration {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Bot настройки
  botToken          String   // зашифрован
  botUsername       String?
  botName           String?
  
  // Web App настройки (для Telegram Web)
  webAppUrl         String?
  webAppShortName   String?
  
  // Webhook настройки
  webhookUrl        String?
  webhookSecret     String?
  
  // Статус
  status            IntegrationStatus @default(DISCONNECTED)
  lastError         String?
  lastCheckedAt     DateTime?
  
  // Метрики
  messagesReceived  Int      @default(0)
  messagesSent      Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("telegram_integrations")
}

// WhatsApp Business интеграции  
model WhatsAppIntegration {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // WhatsApp Business API настройки
  phoneNumberId     String   // WhatsApp Business Phone Number ID
  businessAccountId String   // WhatsApp Business Account ID
  accessToken       String   // зашифрован
  
  // Webhook настройки
  webhookUrl        String?
  verifyToken       String?  // зашифрован
  
  // Номер телефона
  phoneNumber       String   // +7XXXXXXXXXX
  displayName       String?
  
  // Статус
  status            IntegrationStatus @default(DISCONNECTED)
  lastError         String?
  lastCheckedAt     DateTime?
  
  // Метрики
  messagesReceived  Int      @default(0)
  messagesSent      Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("whatsapp_integrations")
}

// Email интеграции
model EmailIntegration {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Основные настройки
  emailAddress      String
  displayName       String?
  
  // SMTP настройки (исходящая почта)
  smtpHost          String
  smtpPort          Int
  smtpSecure        Boolean  @default(true) // SSL/TLS
  smtpUsername      String
  smtpPassword      String   // зашифрован
  
  // IMAP настройки (входящая почта)
  imapHost          String?
  imapPort          Int?
  imapSecure        Boolean  @default(true)
  imapUsername      String?
  imapPassword      String?  // зашифрован
  
  // OAuth2 настройки (для Gmail, Outlook)
  oauth2Provider    String?  // gmail, outlook, etc.
  oauth2ClientId    String?
  oauth2ClientSecret String? // зашифрован
  oauth2RefreshToken String? // зашифрован
  oauth2AccessToken  String? // зашифрован
  oauth2ExpiresAt    DateTime?
  
  // Статус
  status            IntegrationStatus @default(DISCONNECTED)
  lastError         String?
  lastCheckedAt     DateTime?
  
  // Метрики
  emailsReceived    Int      @default(0)
  emailsSent        Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("email_integrations")
}

// Логи интеграций для мониторинга
model IntegrationLog {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  integrationType IntegrationType
  integrationId   String      // ID соответствующей интеграции
  
  action        String      // login, send_message, check_status, etc.
  status        LogStatus   @default(SUCCESS)
  message       String?
  errorDetails  Json?       // детали ошибки
  
  // Метаданные
  userAgent     String?
  ipAddress     String?
  duration      Int?        // milliseconds
  
  createdAt     DateTime    @default(now())

  @@map("integration_logs")
}

// Расширение существующей модели Company
// (это будет добавлено к существующей модели через отношения)
